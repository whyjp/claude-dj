# Auto-detect text files and normalize line endings
* text=auto

# Force LF for scripts and source
*.js text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sh text eol=lf

# Force CRLF for Windows batch files
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.gif binary
*.ico binary
